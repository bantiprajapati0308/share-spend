# Server environment variables
# Copy this to .env and use ONE of the three credential options below

# Port for the Express server
PORT=3001

# Allowed origin(s) for CORS
CLIENT_ORIGIN=http://localhost:5173

# ── Credential option A: inline JSON string ──────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Credential option B: path to JSON file ───────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# ── Credential option C (recommended for local dev) ──────────────────────────
# Just place your service account JSON at server/serviceAccount.json
# No env var needed — the server picks it up automatically.
